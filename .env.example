# Binance API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here
BINANCE_TESTNET=True

# Bot Configuration
TRADING_PAIRS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
TIMEFRAMES=1m,5m,15m,1h,4h,1d

# Position Management
MAX_POSITION_SIZE=0.5
RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_POSITIONS=5

# Scoring Thresholds
LONG_SCORE_THRESHOLD=80
SHORT_SCORE_THRESHOLD=20

# TradingView Webhook
WEBHOOK_PORT=5000
WEBHOOK_SECRET=your_webhook_secret_here

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trading_bot
DB_USER=postgres
DB_PASSWORD=password

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# CryptoQuant API Key (optional)
CRYPTOQUANT_API_KEY=

# Glassnode API Key (optional)
GLASSNODE_API_KEY=
